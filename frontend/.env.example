# Copy this file to .env.local and fill in the values

# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/yappi_sushi?schema=public"

# JWT secret for admin session tokens (generate with: openssl rand -base64 32)
JWT_SECRET="your-super-secret-key-here-replace-me"

# Stripe keys (get from dashboard.stripe.com)
# Public key only — secret key and webhook secret live in backend/.env
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Base URL (used for stripe redirect URLs, etc.)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Backend API base URL
NEXT_PUBLIC_API_URL="http://localhost:4000"
